<body class="bg-gradient-to-br from-gray-100 to-white dark:from-gray-900 dark:to-gray-800 text-gray-900 dark:text-gray-100 min-h-screen font-sans">

<header class="text-white">
    <div class="max-w-7xl mx-auto px-6 py-5">
        <div class="flex items-center justify-between">
            <!-- Mobile Menu -->
            <button id="menu-toggle" class="md:hidden text-3xl">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Title -->
            <div class="flex-1 text-center md:text-left md:pl-2">
                <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Ultimate Loan Officer Sales Coach</h1>
                <p class="text-[#00A89D] text-sm mt-1 hidden md:block">Your complete system for consistent growth</p>
            </div>

            <!-- Controls -->
            <div class="flex items-center gap-2">
                <!-- API Key -->
                <button id="api-key-btn"
                        class="flex items-center gap-2 bg-white/10 hover:bg-white/20 px-3 py-2 rounded-full text-sm font-medium transition-all"
                        title="Manage Grok API Key">
                    <i class="fas fa-key"></i>
                    <span class="hidden md:inline text-xs">API</span>
                </button>

                <!-- Dark Mode Toggle -->
                <button id="theme-toggle"
                        class="flex items-center gap-2 bg-white/10 hover:bg-white/20 px-4 py-2 rounded-full text-sm font-medium transition-all">
                    <i id="theme-icon" class="fas fa-moon"></i>
                    <span class="hidden md:inline">Dark Mode</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Quote Bar (clean separate strip like v2.3) -->
    <div class="bg-gradient-to-r from-[#001429] to-[#00A89D] py-3">
        <div class="max-w-4xl mx-auto px-6 quote-container">
            <div id="quote-display" class="quote-text text-white font-medium text-center">
                "The harder you work, the luckier you get."
            </div>
            <div class="quote-arrows">
                <button id="quote-prev">‹</button>
                <button id="quote-next">›</button>
            </div>
        </div>
    </div>
</header>
