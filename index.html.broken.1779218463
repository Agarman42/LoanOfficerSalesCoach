// Auto-fill text input when selecting from dropdown

document.getElementById('blog-topic-select').addEventListener('change', function() {
    if (this.value) {
        document.getElementById('blog-topic').value = this.value;
    }
});
function copySocialCaption() {
    const captionEl = document.getElementById('social-caption');
    if (!captionEl) return alert('No caption to copy!');

    let text = captionEl.innerText || '';

    // Remove leading indentation/tabs/spaces from each line
    text = text
        .split('\n')
        .map(line => line.trimStart())  // Remove leading whitespace per line
        .join('\n')
        .trim();  // Remove overall leading/trailing

    navigator.clipboard.writeText(text).then(() => {
        alert('Social caption copied! Starts flush left — ready to paste.');
    }).catch(err => {
        console.error('Copy failed:', err);
        alert('Copy failed — try manually selecting the text.');
    });
}

function copyGooglePostWithFormatting() {
    const googleEl = document.getElementById('google-post');
    if (!googleEl) {
        alert('No Google post to copy!');
        return;
    }

    // Get rendered HTML (for rich copy)
    const html = googleEl.innerHTML;

    // Get plain text and clean it
    let plainText = googleEl.innerText || '';

    // Step 1: Remove common character count patterns at the end
    plainText = plainText
        .replace(/\(\d+[, ]?characters?\)$/im, '')     // (1,248 characters)
        .replace(/\(\d+ characters\)$/im, '')          // (1248 characters)
        .replace(/\(1,248 characters\)$/im, '')        // exact match for your example
        .replace(/1,248 characters$/im, '')            // without parentheses
        .replace(/\d+ characters?$/im, '')             // any number + "characters"
        .trim();

    // Step 2: Remove extra leading/trailing whitespace and collapse multiple newlines
    plainText = plainText
        .replace(/\s*\n\s*\n+/g, '\n\n')               // double newlines → single paragraph break
        .replace(/^\s+|\s+$/gm, '')                    // trim each line
        .trim();

    // Create ClipboardItem with cleaned plain text + original rich HTML
    const clipboardItem = new ClipboardItem({
        'text/html': new Blob([html], { type: 'text/html' }),
        'text/plain': new Blob([plainText], { type: 'text/plain' })
    });

    navigator.clipboard.write([clipboardItem]).then(() => {
        alert('Google post copied! Cleaned version (no character count) ready for pasting.');
    }).catch(err => {
        console.error('Rich copy failed:', err);
        // Fallback: copy cleaned plain text
        navigator.clipboard.writeText(plainText).then(() => {
            alert('Copied as clean plain text (no character count) — paste should be perfect now!');
        });
    });
}
